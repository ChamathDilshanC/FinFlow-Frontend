# Public base URL for the FinFlow API (no trailing slash).
# Production (Vercel):
EXPO_PUBLIC_API_BASE_URL=https://fin-flow-backend-theta.vercel.app/api/v1
# Local backend instead: http://localhost:8000/api/v1
# Phone + local PC API (not localhost on device): http://<PC-LAN-IP>:8000/api/v1

# Same Supabase project as the backend — for Google OAuth in the app only.
#
# Supabase → Authentication → URL configuration (after removing old Flutter URIs):
# 1) Redirect URLs — add BOTH if you use Expo Go + later a dev build:
#    - finflow://auth/callback
#    - Run app, press "Continue with Google" once, read Metro log:
#      [FinFlow] OAuth redirectTo → …  (often exp://192.168.x.x:8081/--/auth/callback)
#      Paste that exact exp://… line into Supabase too.
# 2) Site URL — avoid http://localhost:3000-only for mobile; use finflow:// or your prod web URL.
#
# Optional: force OAuth redirect (must exactly match a Supabase Redirect URL entry).
# Leave unset to use Expo’s makeRedirectUri (logs exp://… in Metro for Expo Go).
# EXPO_PUBLIC_AUTH_REDIRECT_URL=exp://192.168.1.26:8081/--/auth/callback
#
# iOS + Expo Go: Google OAuth often needs an HTTPS hop before exp:// (Safari “invalid address”).
# Deploy backend GET /api/v1/auth/oauth-bridge, then add to Supabase Redirect URLs (wildcard):
# https://fin-flow-backend-theta.vercel.app/api/v1/auth/oauth-bridge**
# Bridge is ON by default on iOS when EXPO_PUBLIC_API_BASE_URL starts with https://.
# EXPO_PUBLIC_OAUTH_USE_HTTPS_BRIDGE=0   # force direct exp:// only (e.g. API not deployed yet)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
